# Munin — local product environment (example).
#
# You normally do NOT edit this by hand: `munin setup` / `munin init` writes a
# portable MUNIN_HOME with everything below filled in. This file documents the
# knobs for reference.

# --- Where your local memory lives ---
# MUNIN_HOME=~/.munin            # PGlite store + encrypted blobs + config

# --- Model provider (build + search your memory) ---
# Pick ONE. Your *answers* come from your AI client (e.g. Claude Desktop); these
# settings control how Munin builds and searches the local knowledge graph.

# Local, fully private (recommended): Ollama on your machine.
# LLM_PROVIDER=ollama
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_EMBEDDING_MODEL=bge-m3

# Bring-your-own cloud key (higher-quality extraction). Your prompt + retrieved
# snippets go to YOUR chosen provider under YOUR agreement — never to us.
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# --- Fully-local, zero-egress posture ---
# With MUNIN_LOCAL_MODE=true, Munin structurally refuses to construct any cloud
# provider (Ollama-on-loopback only) — nothing leaves your machine.
# MUNIN_LOCAL_MODE=true
