{
  "name": "munin",
  "private": true,
  "version": "0.1.0",
  "description": "Munin — a private, local memory layer for your AI (open core).",
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm --filter @muninhq/shared --filter @muninhq/engine --filter @muninhq/connector-filesystem --filter @muninhq/config-generic-baseline --filter @muninhq/config-personal --filter @muninhq/config-generic-demo --filter munin-mcp --filter @muninhq/mcp build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm -r test",
    "acceptance:clean-install": "bash scripts/acceptance/clean-install-test.sh",
    "migrate": "pnpm --filter munin-mcp migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<0.25.0": ">=0.25.0"
    }
  }
}
