{
  "name": "@muninhq/config-personal",
  "version": "0.1.0",
  "private": false,
  "license": "AGPL-3.0-only",
  "description": "Munin default local (personal) configuration — what `munin init` selects for the open-core local product. The hosted/managed product and the verticals are separate and closed.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./eval": "./src/eval/index.ts"
  },
  "files": ["dist", "LICENSE", "README.md"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../../scripts/esm-fix.mjs",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./eval": {
        "types": "./dist/eval/index.d.ts",
        "default": "./dist/eval/index.js"
      }
    }
  },
  "dependencies": {
    "@muninhq/shared": "workspace:*"
  }
}
