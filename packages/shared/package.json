{
  "name": "@muninhq/shared",
  "version": "0.1.0",
  "private": false,
  "license": "AGPL-3.0-only",
  "description": "Munin shared types and configuration schema — part of the open-core local product. The hosted/managed product and the verticals are separate and closed.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "LICENSE", "README.md"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/esm-fix.mjs",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  }
}
